print("=== CÁLCULO DO FATORIAL ===\n")

n = int(input("Digite a quantidade de produtos distintos: "))

if n < 0:

    print("\nNão existe fatorial para números negativos.")

else:

    resultado = 1

    for i in range(1, n + 1):

        resultado *= i

    print("\nQuantidade de organizações possíveis:", resultado)
